---
import type { Speaker } from '../data/speakers';
import ImgSlot from './ImgSlot.astro';

interface Props {
  speaker: Speaker;
  showBio?: boolean;
  featured?: boolean;
}

const { speaker, showBio = true, featured = false } = Astro.props;

const statusLabel =
  speaker.tier === 'committed' ? 'Committed' : 'In discussion';
const statusClass =
  speaker.tier === 'committed' ? 'pill-green' : 'pill-amber';
---

<div class:list={['speaker', { 'speaker--featured': featured }]}>
  <ImgSlot label={speaker.imageLabel} src={speaker.imageSrc} alt={speaker.name} />
  <div>
    <span class={`pill ${statusClass}`}>{statusLabel}</span>
    <h3>{speaker.name}</h3>
    <p class="role">{speaker.role}</p>
    {showBio && (
      <p class="text-soft" style="font-size:15.5px">{speaker.bio}</p>
    )}
    {speaker.socials.some((s) => s.count !== 'TBC') && (
      <>
        <div class="socials">
          {speaker.socials.map((s) => (
            <div class="social">
              <div class="n">{s.count}</div>
              <div class="p">{s.platform}</div>
            </div>
          ))}
        </div>
        <div class="reach">
          <span class="big">{speaker.reach}</span> combined audience*
        </div>
      </>
    )}
  </div>
</div>
