---
import { SPEAKER_IMAGES as SPEAKER_PHOTOS } from '../data/assets';

interface Badge {
  mono?: string;
  text: string;
}

interface Cta {
  href: string;
  label: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  badges?: Badge[];
  primaryCta?: Cta;
  secondaryCta?: Cta;
}

const {
  eyebrow,
  title,
  lead,
  badges = [],
  primaryCta = { href: '/waitlist', label: 'Join waitlist' },
  secondaryCta = { href: '/sponsors', label: 'Become a sponsor' },
} = Astro.props;

const speakers = [
  { src: SPEAKER_PHOTOS['daniel-priestley'], name: 'Daniel Priestley', pos: 'left' },
  { src: SPEAKER_PHOTOS['dan-koe'], name: 'Dan Koe', pos: 'center' },
  { src: SPEAKER_PHOTOS['tom-noske'], name: 'Tom Noske', pos: 'right' },
];
---

<header class="hero-speakers">
  <div class="hero-speakers-bg" aria-hidden="true">
    {speakers.map((s) => (
      <div class:list={['hero-speakers-panel', `hero-speakers-panel--${s.pos}`]}>
        <img src={s.src} alt="" loading="eager" decoding="async" />
      </div>
    ))}
    <div class="hero-speakers-scrim" />
  </div>
  <div class="hero-speakers-inner container">
    <p class="eyebrow eyebrow-light">{eyebrow}</p>
    <h1 set:html={title} />
    {lead && <p class="hero-sub">{lead}</p>}
    {badges.length > 0 && (
      <div class="hero-meta">
        {badges.map((badge) => (
          <span class="hero-meta-pill">
            {badge.mono && <span class="hero-meta-mono">{badge.mono}</span>}
            {badge.text}
          </span>
        ))}
      </div>
    )}
    {(primaryCta || secondaryCta) && (
      <div class="hero-ctas">
        {primaryCta && <a class="btn-white" href={primaryCta.href}>{primaryCta.label}</a>}
        {secondaryCta && (
          secondaryCta.href === '#waitlist' ? (
            <a class="btn-outline" href="#waitlist" data-waitlist-open>{secondaryCta.label}</a>
          ) : (
            <a class="btn-outline" href={secondaryCta.href}>{secondaryCta.label}</a>
          )
        )}
      </div>
    )}
  </div>
</header>
