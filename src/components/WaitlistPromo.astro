<section class="waitlist-promo section-dark">
  <div class="wrap waitlist-promo-inner">
    <div class="waitlist-promo-copy">
      <p class="kicker">Your voice shapes the event</p>
      <h2>Join the waitlist. Tell us who you want in Bali.</h2>
      <p class="lead">
        We're curating speakers, topics, and partners based on what you tell us.
        Who are we missing? Who would you pay to see? Step through the form and make your pick heard.
      </p>
    </div>
    <div class="waitlist-promo-actions">
      <button type="button" class="btn-waitlist-hero" data-waitlist-open>
        Join the waitlist
      </button>
      <p class="waitlist-promo-meta">Name · email · country · your speaker picks · ~2 min</p>
    </div>
  </div>
</section>
