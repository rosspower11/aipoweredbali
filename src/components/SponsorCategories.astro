---
import { PARTNER_CATEGORIES } from '../data/sponsors';
import { SPONSOR_TARGETS, sponsorLogoUrl } from '../data/sponsor-targets';

const pillarLabels: Record<string, string> = {
  human: '01 · Human',
  artificial: '02 · Artificial',
  divine: '03 · Divine',
};

const logoByName = Object.fromEntries(SPONSOR_TARGETS.map((t) => [t.name, t.domain]));
---

<div class="partner-pillars">
  {PARTNER_CATEGORIES.map((cat) => (
    <div class="partner-pillar">
      <p class="kicker">{pillarLabels[cat.pillar]}</p>
      <h3>{cat.title}</h3>
      <p class="partner-target-note">
        <span class="pill pill-target">Target</span>
        Brands we are actively pursuing for sponsorship. Not confirmed partners.
      </p>
      <div class="partner-brands partner-brands--logos">
        {cat.brands.map((brand) => {
          const domain = logoByName[brand];
          return domain ? (
            <div class="partner-brand-logo" title={`${brand} — target sponsor`}>
              <img
                src={sponsorLogoUrl(domain)}
                alt={brand}
                loading="lazy"
                decoding="async"
                onerror="this.hidden=true;this.nextElementSibling.hidden=false"
              />
              <span class="partner-brand-fallback" hidden>{brand}</span>
            </div>
          ) : (
            <span class="partner-brand">{brand}</span>
          );
        })}
      </div>
    </div>
  ))}
</div>
<p class="partner-cta-line">
  <span class="partner-cta-bar" aria-hidden="true"></span>
  Official sponsorship outreach began July 2026. Interested in partnering? Let's discuss something that fits.
</p>
