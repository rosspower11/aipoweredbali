---
interface Props {
  label: string;
  minHeight?: string;
  src?: string;
  alt?: string;
}

const { label, minHeight, src, alt = '' } = Astro.props;
const style = minHeight ? `min-height:${minHeight}` : undefined;
---

<div class="img-slot" data-label={label} style={style}>
  {src && <img src={src} alt={alt} />}
  <i>◱</i>
</div>
