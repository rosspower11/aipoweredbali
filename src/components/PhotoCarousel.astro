---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  label?: string;
  images: ImageItem[];
  variant?: 'single' | 'double';
  dark?: boolean;
}

const { label, images, variant = 'single', dark = true } = Astro.props;
const track = [...images, ...images];
const midpoint = Math.ceil(images.length / 2);
const rowA = images.slice(0, midpoint);
const rowB = images.slice(midpoint);
---

{variant === 'single' ? (
  <div class:list={['carousel', { 'carousel--light': !dark }]}>
    {label && <div class="carousel-label">{label}</div>}
    <div class="carousel-track">
      {track.map((img, i) => (
        <div class="carousel-img">
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
) : (
  <div class:list={['carousel-double', { 'carousel-double--light': !dark }]}>
    {label && <div class="carousel-label">{label}</div>}
    <div class="carousel-row forward">
      {[...rowA, ...rowA].map((img, i) => (
        <div class="carousel-img">
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
    <div class="carousel-row reverse">
      {[...rowB, ...rowB].map((img, i) => (
        <div class="carousel-img">
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
)}
