---
import ImgSlot from './ImgSlot.astro';
import { SPEAKERS, MYSTERY_SPEAKER_COUNT } from '../data/speakers';
import SpeakerMystery from './SpeakerMystery.astro';

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class:list={[{ dark }]} style={dark ? undefined : 'background:var(--paper)'}>
  <div class="wrap">
    <div class="kicker">The Line-Up</div>
    <h2>Voices you'll meet in Bali.</h2>
    <p class="lead mb-44">Confirmed and in-discussion speakers — with more announcements coming.</p>
    <div class="speaker-teaser-grid">
      {SPEAKERS.map((speaker) => (
        <a href="/speakers" class="speaker-teaser">
          <ImgSlot label={speaker.imageLabel} src={speaker.imageSrc} alt={speaker.name} minHeight="200px" />
          <span class={`pill ${speaker.status === 'confirmed' ? 'pill-green' : 'pill-amber'}`} style="margin-bottom:8px">
            {speaker.status === 'confirmed' ? '✓ Confirmed' : '◌ In discussion'}
          </span>
          <h4>{speaker.name}</h4>
        </a>
      ))}
      {Array.from({ length: MYSTERY_SPEAKER_COUNT }).map(() => (
        <SpeakerMystery />
      ))}
    </div>
    <p style="margin-top:28px;text-align:center">
      <a href="/speakers" class="btn btn-dark">See full line-up</a>
    </p>
  </div>
</section>
