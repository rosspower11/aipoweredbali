---
import ImgSlot from './ImgSlot.astro';
import { FEATURED_SPEAKERS, TARGET_SPEAKERS } from '../data/speakers';

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class:list={[{ dark: dark, 'section-dark': dark }, { 'section-light': !dark }]}>
  <div class="wrap">
    <p class="kicker">The Line-Up</p>
    <h2>Voices you'll meet in Bali.</h2>
    <p class="lead mb-44">Confirmed and in-discussion speakers, with more announcements coming.</p>
    <div class="speaker-teaser-grid">
      {FEATURED_SPEAKERS.map((speaker) => (
        <a href="/speakers" class="speaker-teaser">
          <ImgSlot label={speaker.imageLabel} src={speaker.imageSrc} alt={speaker.name} minHeight="200px" />
          <span class={`pill ${speaker.tier === 'committed' ? 'pill-green' : 'pill-amber'}`} style="margin-bottom:8px">
            {speaker.tier === 'committed' ? 'Committed' : 'In discussion'}
          </span>
          <h4>{speaker.name}</h4>
        </a>
      ))}
      {TARGET_SPEAKERS.slice(0, 6).map((t) => (
        <a href="/speakers" class="speaker-teaser speaker-teaser--target">
          <div class="target-pill-preview">?</div>
          <span class="pill pill-muted">Target</span>
          <h4>{t.name}</h4>
        </a>
      ))}
    </div>
    <p style="margin-top:28px;text-align:center">
      <a href="/speakers" class="btn-dark">See full line-up</a>
    </p>
  </div>
</section>
