---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerHero from '../components/SpeakerHero.astro';
import BuildWithUs from '../components/BuildWithUs.astro';
import ImageBreak from '../components/ImageBreak.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SpeakerTargetPills from '../components/SpeakerTargetPills.astro';
import SpeakerForm from '../components/SpeakerForm.astro';
import {
  COMMITTED_SPEAKERS,
  IN_DISCUSSION_SPEAKERS,
  TARGET_SPEAKERS,
} from '../data/speakers';
import { BALI_NATURE } from '../data/assets';
---

<BaseLayout
  title="Speakers · April 2027"
  description="Daniel Priestley committed. Dan Koe and Tom Noske in discussion. World-class targets across Human, Artificial and Divine. Apply to speak at AI Powered Bali."
>
  <SpeakerHero
    eyebrow="The Line-Up · Campaign live July 2026"
    title="The names your audience is already learning from."
    lead="Practical builders. World-class teachers. We're actively pursuing speakers for April 2027. Daniel is confirmed. Dan and Tom are in discussion. The rest are targets we're going after right now."
    badges={[
      { mono: 'Committed', text: 'Daniel Priestley' },
      { mono: 'In discussion', text: 'Dan Koe · Tom Noske' },
      { mono: 'Status', text: 'Speaker outreach in progress' },
    ]}
    primaryCta={{ href: '#apply', label: 'Apply to speak' }}
    secondaryCta={{ href: '#waitlist', label: 'Join waitlist' }}
  />

  <BuildWithUs variant="dark" />

  <section class="section-dark" style="padding-top:0">
    <div class="wrap">
      <p class="kicker">Committed</p>
      <h2>Confirmed for April 2027.</h2>
      <p class="lead mb-44">Headline speakers locked in. More announcements coming as conversations close.</p>
      {COMMITTED_SPEAKERS.map((speaker) => (
        <SpeakerCard speaker={speaker} featured />
      ))}
    </div>
  </section>

  <section class="section-dark">
    <div class="wrap">
      <div class="speakers-split">
        <div class="speakers-split-col">
          <p class="kicker">In discussion</p>
          <p class="text-soft" style="margin-bottom:28px;font-size:15px">Active conversations. Not confirmed yet.</p>
          {IN_DISCUSSION_SPEAKERS.map((speaker, i) => (
            <>
              {i > 0 && <div class="divider" />}
              <SpeakerCard speaker={speaker} showBio={false} />
            </>
          ))}
        </div>
        <div class="speakers-split-col">
          <p class="kicker">Initial targets</p>
          <p class="text-soft" style="margin-bottom:28px;font-size:15px">
            <span class="pill pill-target">Target</span> The caliber we're pursuing. Outreach in progress.
          </p>
          <SpeakerTargetPills targets={TARGET_SPEAKERS} />
        </div>
      </div>
    </div>
  </section>

  <ImageBreak src={BALI_NATURE} alt="Bali" label="April 2027 · Bali" height="min(36vh, 360px)" />

  <section class="section-dark" style="padding-top:0">
    <div class="wrap">
      <div class="grid g2" style="gap:52px;align-items:start">
        <div>
          <p class="kicker">What unites them</p>
          <h2 style="font-size:clamp(28px,4vw,44px)">Practical builders.</h2>
        </div>
        <div class="quote" style="font-style:normal">
          The names your audience is already learning from, now in the room where Bali's entrepreneur community gathers.
        </div>
      </div>
      <p class="footnote" style="margin-top:48px">*Follower counts from public trackers, July 2026. Indicative and rounded. Target names represent conversations in progress, not confirmed bookings.</p>
    </div>
  </section>

  <section id="apply" class="section-light">
    <div class="wrap">
      <SpeakerForm />
    </div>
  </section>
</BaseLayout>
