---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SpeakerMystery from '../components/SpeakerMystery.astro';
import SpeakerForm from '../components/SpeakerForm.astro';
import { SPEAKERS, MYSTERY_SPEAKER_COUNT } from '../data/speakers';
---

<BaseLayout
  title="Speakers · April 2027"
  description="Daniel Priestley confirmed. Dan Koe and Tom Noske in discussion. Plus more speakers to be announced. Apply to speak at AI Powered Bali."
  ctaHref="/waitlist"
  ctaLabel="Join waitlist"
>
  <header class="hero" style="padding-bottom:64px">
    <div class="wrap">
      <div class="kicker">The Line-Up · April 2027</div>
      <h1>Voices this audience already follows.</h1>
      <p class="lead">A combined audience of <b style="color:#fff">4.5M+ followers</b> across the confirmed and target line-up — and more announcements coming.</p>
    </div>
  </header>

  <section class="dark" style="padding-top:0">
    <div class="wrap">
      {SPEAKERS.map((speaker, i) => (
        <>
          {i > 0 && <div class="divider" />}
          <SpeakerCard speaker={speaker} />
        </>
      ))}

      <div class="divider" />

      <div class="kicker">More to come</div>
      <h2 style="font-size:clamp(24px,3vw,36px);margin-bottom:32px">Further speakers being announced.</h2>
      <div class="speaker-grid">
        {Array.from({ length: MYSTERY_SPEAKER_COUNT }).map(() => (
          <SpeakerMystery />
        ))}
      </div>

      <p class="footnote">*Follower counts from public trackers, July 2026 — indicative and rounded. Further speakers to be announced across AI, business, creativity and consciousness.</p>
    </div>
  </section>

  <section style="background:var(--paper)">
    <div class="wrap">
      <SpeakerForm />
    </div>
  </section>
</BaseLayout>
