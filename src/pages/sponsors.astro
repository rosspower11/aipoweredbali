---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SponsorBenefits from '../components/SponsorBenefits.astro';
import SponsorCategories from '../components/SponsorCategories.astro';
import SponsorForm from '../components/SponsorForm.astro';
import PackageTiers from '../components/PackageTiers.astro';
---

<BaseLayout
  title="Sponsor · April 2027"
  description="Partner with AI Powered Bali. 1,000+ high-intent entrepreneurs, premium speaker association, full lead capture. Human, Artificial and Divine sponsorship categories."
  ctaHref="#partner"
  ctaLabel="Become a sponsor"
>
  <Hero
    eyebrow="Partners · April 2027"
    title="Why sponsor this event."
    lead="1,000+ paying entrepreneurs who run on your tools. A concentrated audience across Pan-Asia, Middle East and ANZ. Workshop format, not a trade show booth."
    badges={[
      { mono: 'Audience', text: '700 to 1,000 entrepreneurs' },
      { mono: 'Speaker', text: 'Daniel Priestley committed' },
      { mono: 'Format', text: 'Workshop-style, high dwell time' },
    ]}
    primaryCta={{ href: '#partner', label: 'Become a sponsor' }}
    secondaryCta={{ href: '/waitlist', label: 'Join waitlist' }}
  />

  <section class="section-dark" style="padding-top:0">
    <div class="wrap">
      <p class="kicker">The opportunity</p>
      <h2>What you get as a sponsor.</h2>
      <SponsorBenefits />
    </div>
  </section>

  <section class="section-dark">
    <div class="wrap">
      <p class="kicker">Our partners</p>
      <h2>Brands that serve entrepreneurs.</h2>
      <p class="lead mb-44">Sponsorship categories mapped to our three pillars. Category exclusivity available for founding partners.</p>
      <SponsorCategories />
    </div>
  </section>

  <section id="partner" class="section-light">
    <div class="wrap text-center" style="max-width:860px">
      <p class="kicker">Partner with us</p>
      <h2>Founding partners write the story with us.</h2>
      <p class="lead" style="margin:0 auto 30px">We're selecting a small number of partners whose products this audience already runs on. Founding partners shape the event from day one: stage presence, category exclusivity, content rights, and first position across both 2026 and 2027 events.</p>
      <div class="card" style="text-align:left;margin-bottom:34px">
        <div class="label">Sponsorship packages</div>
        <p class="text-soft">Full partnership tiers are being finalised now. Early conversations get first pick of category exclusivity and headline positioning.</p>
      </div>
      <PackageTiers />
      <div style="margin-top:48px">
        <SponsorForm />
      </div>
    </div>
  </section>
</BaseLayout>
