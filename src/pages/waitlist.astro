---
import '../styles/global.css';
import WaitlistForm from '../components/WaitlistForm.astro';
import { SITE_NAME } from '../data/site';
import { FAVICON, LOGO_WHITE } from '../data/cdn';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join the Waitlist · {SITE_NAME}</title>
    <meta name="description" content="Join the waitlist for AI Powered Bali, April 2027. 700 to 1,000 entrepreneurs. Daniel Priestley confirmed." />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={`Join the Waitlist · ${SITE_NAME}`} />
    <meta property="og:description" content="April 2027 · Bali · 700 to 1,000 entrepreneurs. Daniel Priestley confirmed." />
    <link rel="icon" href={FAVICON} />
    <link rel="apple-touch-icon" href={FAVICON} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="waitlist-page">
      <header class="waitlist-header">
        <a href="/" class="nav-logo">
          <img class="nav-logo-img" src={LOGO_WHITE} alt="AI Powered" width="132" height="24" />
        </a>
      </header>
      <main class="waitlist-main">
        <div class="waitlist-inner">
          <p class="eyebrow eyebrow-light">April 2027 · Bali</p>
          <h1>The premier entrepreneur conference for the builders of the AI era.</h1>
          <p class="subline">April 2027 · Bali · 700 to 1,000 entrepreneurs</p>
          <WaitlistForm />
          <div class="waitlist-proof">
            <span>700 to 1,000 entrepreneurs</span>
            <span>Priestley confirmed</span>
            <span>April 2027</span>
          </div>
          <p style="margin-top:32px">
            <a class="btn-outline" href="/sponsors">Become a sponsor</a>
          </p>
        </div>
      </main>
    </div>
  </body>
</html>
