---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CampaignBanner from '../components/CampaignBanner.astro';
import PoweredBy from '../components/PoweredBy.astro';
import WhoWeMissing from '../components/WhoWeMissing.astro';
import WaitlistPromo from '../components/WaitlistPromo.astro';
import BuildWithUs from '../components/BuildWithUs.astro';
import SponsorTargetMarquee from '../components/SponsorTargetMarquee.astro';
import SpeakerTeaserStrip from '../components/SpeakerTeaserStrip.astro';
import FounderSection from '../components/FounderSection.astro';
import CampaignRoadmap from '../components/CampaignRoadmap.astro';
import ImageBreak from '../components/ImageBreak.astro';
import BaliGallery from '../components/BaliGallery.astro';
import {
  BALI_HERO,
  BALI_MOUNTAINS,
  BALI_NATURE,
  BALI_SURF,
  MERU_HOTEL,
  MERU_HOTEL_2,
} from '../data/assets';
---

<BaseLayout
  title="The Best AI Gathering for Creator-Entrepreneurs in Bali"
  description="Be part of the best AI gathering for creator-entrepreneurs Bali has ever witnessed. April 2027 flagship. Daniel Priestley confirmed. Looking for partners, venues, sponsors and speakers."
>
  <Hero
    eyebrow="Bali · April 2027 · Building in public from July 2026"
    title="Be part of the best AI gathering for <strong>creator-entrepreneurs</strong> Bali has ever witnessed."
    lead="A 2 to 3 day immersive event for 700 to 1,000 builders, creators and operators. We're actively looking for partners, venues, collaborators, sponsors and speakers. This is your opportunity to get in early."
    badges={[
      { mono: 'Speaker', text: 'Daniel Priestley confirmed' },
      { mono: 'Status', text: 'In progress · outreach live' },
      { mono: 'Line-up', text: 'Dan Koe and Tom Noske in discussion' },
    ]}
    primaryCta={{ href: '#waitlist', label: 'Join waitlist', waitlistModal: true }}
    secondaryCta={{ href: '/sponsors', label: 'Partner with us' }}
    bgImage={BALI_HERO}
    bgPosition="center 40%"
  />

  <CampaignBanner />

  <PoweredBy />

  <WhoWeMissing />

  <BuildWithUs variant="accent" />

  <ImageBreak src={BALI_SURF} alt="Surf and coastline in Bali" label="Bali · April 2027" height="min(44vh, 440px)" />

  <SponsorTargetMarquee />

  <section id="event" class="section-light" style="padding-top:0">
    <div class="wrap">
      <div class="facts">
        <div class="card"><div class="label">What</div><p>2 to 3 day immersive, workshop-style conference. Practical. Tactical. For builders and creators.</p></div>
        <div class="card"><div class="label">When</div><p><b>April 2027.</b> September 2026 ignition in Canggu (300 seats). Sponsor and speaker campaign live from July.</p></div>
        <div class="card"><div class="label">Where</div><p>Bali, Indonesia. Targeting the Kura Kura Bali Special Economic Zone, with venue partners across the island.</p></div>
        <div class="card"><div class="label">Who</div><p>700 to 1,000 paying entrepreneurs: founders, creators, coaches and operators. Builders, not browsers.</p></div>
      </div>
      <div class="venue-card">
        <div class="venue-card-photo">
          <img src={MERU_HOTEL} alt="The Meru Sanur, Bali" loading="lazy" />
        </div>
        <div class="venue-card-copy">
          <p class="label">Venues · In conversation</p>
          <h3 style="margin-bottom:12px">We're scouting Bali's best spaces.</h3>
          <p class="text-soft" style="font-size:15px;line-height:1.75">
            From premium resorts like The Meru Sanur to convention-grade facilities and creative campuses.
            If you operate a venue or hospitality brand in Bali, we want to hear from you.
          </p>
          <p style="margin-top:16px"><a href="/sponsors#partner" class="btn-dark" style="display:inline-block;padding:12px 24px;font-size:12px">Venue & partner enquiry</a></p>
        </div>
      </div>
    </div>
  </section>

  <section id="vision" class="section-dark" style="padding-top:64px">
    <div class="wrap">
      <div class="vision-with-photo">
        <div>
          <p class="kicker">The Vision</p>
          <h2>Become AI powered.<br>Remain human.</h2>
          <p class="lead">AI is handing back the most valuable asset an entrepreneur has: time. This event is about what you do with it.</p>
        </div>
        <div class="vision-photo">
          <img src={BALI_NATURE} alt="Bali jungle and nature" loading="lazy" />
        </div>
      </div>
      <div class="grid g3">
        <div class="card">
          <p class="pillar-num">01 · Human</p>
          <h3>Human</h3>
          <p class="text-soft">Connection. Offline, in-person experiences. Music, arts and creativity woven through the entire event. Real rooms, real relationships.</p>
        </div>
        <div class="card">
          <p class="pillar-num">02 · Artificial</p>
          <h3>Artificial</h3>
          <p class="text-soft">Leverage. The practical power of AI to take time back, build leaner businesses, and create a more meaningful life outside the screen.</p>
        </div>
        <div class="card">
          <p class="pillar-num">03 · Divine</p>
          <h3>Divine</h3>
          <p class="text-soft">Consciousness. Spiritual connectedness and presence. The dimension Bali does better than anywhere on earth.</p>
        </div>
      </div>
      <div class="quote" style="margin-top:26px">Educate. Entertain. Inspire. One event, three threads. Curated for the crowd, not for the sponsors' logos.</div>
    </div>
  </section>

  <SpeakerTeaserStrip dark />

  <WaitlistPromo />

  <ImageBreak src={BALI_MOUNTAINS} alt="Bali mountains and rice terraces" label="Where builders gather" align="center" />

  <CampaignRoadmap />

  <BuildWithUs variant="dark" />

  <FounderSection />

  <section id="why-bali" class="section-light">
    <div class="wrap">
      <div class="grid g2" style="align-items:center;gap:52px">
        <div class="img-slot" style="min-height:440px;border-radius:12px;overflow:hidden">
          <img src={BALI_MOUNTAINS} alt="Bali landscape" loading="lazy" />
        </div>
        <div>
          <p class="kicker">Why Bali</p>
          <h2>What people think Bali is.</h2>
          <div class="strike-list">
            <p>Yoga retreats.</p>
            <p>Cheap living, slow pace.</p>
            <p>Backpackers on a budget.</p>
            <p>Digital nomads in beach cafés.</p>
            <p>A place to escape, and start.</p>
            <p>Not a place to build and scale.</p>
          </div>
          <p style="margin-top:22px" class="text-soft">This was the story for 15 years.</p>
          <p style="font-weight:700;font-size:18px">It's not the story anymore.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-dark">
    <div class="wrap">
      <p class="kicker">Why Bali</p>
      <h2>What Bali actually is now.</h2>
      <div class="grid g2" style="margin-top:14px">
        <div style="display:grid;gap:22px">
          <div class="card">
            <div class="stat">50,000+</div>
            <p class="stat-sub">Long-term foreign residents, entrepreneurs and digital professionals currently based in Bali.</p>
          </div>
          <div class="card">
            <div class="stat">35%</div>
            <p class="stat-sub">of digital nomads in Bali earn $100,000 to $250,000 annually. Ready and willing to invest to go further. <i>This is not a broke crowd.</i></p>
          </div>
          <div class="card">
            <div class="stat">150+</div>
            <p class="stat-sub">Coworking spaces across the island.</p>
          </div>
        </div>
        <div style="display:grid;gap:22px">
          <div class="card">
            <div class="label">Bali can handle the demand</div>
            <p style="font-size:15px;color:var(--text-grey);line-height:1.85">
              <b style="color:#fff">Massive throughput:</b> 74 events and 95,000 attendees projected in just 90 days.<br>
              <b style="color:#fff">The bleisure edge:</b> peak attendance driven by the world's top business and leisure appeal.<br>
              <b style="color:#fff">Elite infrastructure:</b> world-class venues like the Bali International Convention Centre.<br>
              <b style="color:#fff">Battle-tested:</b> proven host of high-stakes global summits including G20 and IMF.<br>
              <b style="color:#fff">Global gateway:</b> direct access from Singapore, Dubai and Sydney.
            </p>
          </div>
          <div class="quote">"As a teenager, I went to Bali a lot, which is why, when we bought Necker Island, we made it like a mini Bali."<br><b style="font-style:normal;display:block;margin-top:10px">Richard Branson</b></div>
        </div>
      </div>
      <BaliGallery title="The island" />
    </div>
  </section>

  <ImageBreak src={MERU_HOTEL_2} alt="Premium Bali venue" label="Venue partners welcome" height="min(40vh, 400px)" align="bottom" />

  <section class="section-light">
    <div class="wrap">
      <div class="grid g2" style="gap:52px;align-items:start">
        <div>
          <p class="kicker">The Gap</p>
          <h2>Here's what we noticed.</h2>
          <p class="lead" style="margin-bottom:20px">The same entrepreneurs, watching the same podcasts, wishing they could meet the people teaching them. Learn from them. Connect with them. Buy from them.</p>
          <p class="text-soft" style="margin-bottom:20px">They fly to Singapore, Dubai and London for the "real" events. Then they come back to Bali.</p>
          <p style="font-size:19px;font-weight:600">They're not looking to be motivated. They're looking to be <u>shown how</u>.</p>
        </div>
        <div style="display:grid;gap:22px">
          <div class="card">
            <div class="label">What exists today</div>
            <p class="text-soft" style="font-size:15.5px;line-height:1.8">Steven Bartlett came to Bali in 2025. Over 1,000 people showed up. Twice. Crypto and AI events pull 2,000+, but they're unaligned to the builders here: either purely motivational, or so sponsor-focused you leave unsure what you came for.</p>
          </div>
          <div class="quote light-quote" style="font-style:normal">
            This is about building something curated <b>for the crowd</b>.<br>
            <b>Practical. Tactical. For builders and creators.</b><br>
            People who want to meet Daniel Priestley, not just watch YouTube.
          </div>
        </div>
      </div>
    </div>
  </section>

  <SponsorTargetMarquee compact />

  <section class="section-dark">
    <div class="wrap text-center" style="max-width:720px">
      <p class="kicker">April 2027</p>
      <h2>Be first in the room.</h2>
      <p class="lead" style="margin:0 auto 30px">Join the waitlist for early access to tickets, speaker announcements and founding community events. Or reach out if you want to help build it.</p>
      <div class="hero-ctas" style="justify-content:center">
        <button type="button" class="btn-white" data-waitlist-open>Join waitlist</button>
        <a class="btn-outline" href="/sponsors">Partner with us</a>
      </div>
    </div>
  </section>
</BaseLayout>
